<div class="relative group <%= @html_options[:wrapper_class] %>">
  <% if icon.present? && icon_position == :leading %>
    <span class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none z-10">
      <%= render Ui::IconComponent.new(name: icon, size_class: "text-xl text-on-surface-variant") %>
    </span>
  <% end %>
  <% common = { class: input_classes, placeholder: placeholder }.merge(@html_options.except(:wrapper_class, :class)) %>
  <% common[:id] = field_id if field_id.present? %>
  <% if @form && @attribute %>
    <% case @type
       when "email" %>
      <%= @form.email_field @attribute, **common %>
    <% when "password" %>
      <%= @form.password_field @attribute, **common %>
    <% when "number" %>
      <%= @form.number_field @attribute, **common.merge(class: "#{input_classes} ui-input-no-spin") %>
    <% else %>
      <%= @form.text_field @attribute, **common %>
    <% end %>
  <% else %>
    <%= tag.input(**common.merge(type: @type, name: @name, value: @value)) %>
  <% end %>
  <% if icon.present? && icon_position == :trailing %>
    <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none z-10">
      <%= render Ui::IconComponent.new(name: icon, size_class: "text-xl text-on-surface-variant") %>
    </span>
  <% end %>
  <% if error.present? %>
    <%= render Ui::InlineErrorComponent.new(error) %>
  <% end %>
</div>
