<%= turbo_frame_tag dom_id(listing, :card) do %>
<article class="bg-surface-container-lowest p-5 rounded-xl border border-outline-variant/20">
  <div class="flex items-start justify-between gap-4">
    <div class="space-y-1 min-w-0">
      <div class="flex items-center gap-2 text-on-surface-variant">
        <%= render Ui::SportIconComponent.new(sport: listing.sport, class: "w-4 h-4") %>
        <span class="text-[10px] font-semibold uppercase tracking-widest"><%= listing.sport.humanize %></span>
      </div>
      <h3 class="font-headline font-bold leading-tight <%= compact ? "text-base" : "text-lg" %>"><%= listing.title %></h3>
      <% if listing_rain_warning?(listing) %>
        <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">⚠️ Có thể mưa</span>
      <% end %>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <% if current_user %>
        <% if bookmarked %>
          <%= button_to listing_bookmark_path(listing), method: :delete,
                data: { turbo_stream: true, turbo_frame: "_top" },
                class: "p-1.5 rounded-full hover:cursor-pointer hover:bg-surface-container text-on-surface-variant flex items-center justify-center",
                title: "Bỏ lưu" do %>
            <%= helpers.inline_svg "bookmark_filled", css_class: "w-5 h-5" %>
          <% end %>
        <% else %>
          <%= button_to listing_bookmark_path(listing), method: :post,
                data: { turbo_stream: true, turbo_frame: "_top" },
                class: "p-1.5 rounded-full hover:cursor-pointer hover:bg-surface-container text-on-surface-variant",
                title: "Lưu tin" do %>
            <%= helpers.inline_svg "bookmark_outline", css_class: "w-5 h-5" %>
          <% end %>
        <% end %>
      <% end %>
      <%= link_to listing_path(listing),
            class: "p-1.5 rounded-full hover:bg-surface-container text-on-surface-variant flex items-center justify-center",
            title: "Xem chi tiết",
            data: { turbo_frame: "_top" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path fill-rule="evenodd" d="M12.97 3.97a.75.75 0 0 1 1.06 0l7.5 7.5a.75.75 0 0 1 0 1.06l-7.5 7.5a.75.75 0 1 1-1.06-1.06l6.22-6.22H3a.75.75 0 0 1 0-1.5h16.19l-6.22-6.22a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      <% end %>
    </div>
  </div>
  <div class="mt-4 space-y-2 text-sm text-on-surface-variant">
    <p class="flex items-center gap-2"><%= render Ui::IconComponent.new(name: "schedule", size_class: "text-base") %><%= l(listing.start_at, format: :short) %></p>
    <p class="flex items-center gap-2"><%= render Ui::IconComponent.new(name: "location_on", size_class: "text-base") %><%= listing.location_name %></p>
  </div>
  <% if listing.gender_requirement.present? || listing.play_format.present? %>
    <div class="mt-3 flex flex-wrap gap-2">
      <% if listing.gender_requirement.present? %>
        <span class="inline-flex items-center gap-1 text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full bg-secondary-container/40 text-on-secondary-container">
          <%= render Ui::IconComponent.new(name: "wc", size_class: "text-[10px]") %>
          <%= listing.gender_requirement_label %>
        </span>
      <% end %>
      <% if listing.play_format.present? %>
        <span class="inline-flex items-center gap-1 text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full bg-tertiary-container/40 text-on-tertiary-container">
          <%= render Ui::IconComponent.new(name: "sports_tennis", size_class: "text-[10px]") %>
          <%= listing.play_format_label %>
        </span>
      <% end %>
    </div>
  <% end %>
  <% if show_actions %>
    <div class="mt-4 flex items-center justify-end gap-4">
      <%= link_to "Sửa", edit_listing_path(listing), class: "text-sm font-bold text-primary", data: { turbo_frame: "_top" } %>
    </div>
  <% end %>
</article>
<% end %>
