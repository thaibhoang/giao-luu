<header
  class="<%= class_names(
    "fixed top-0 left-0 right-0 z-50",
    "bg-surface/80 dark:bg-[#111827]/80 backdrop-blur-xl border-none",
    html_class,
    html_options[:class]
  ) %>"
  <%= tag.attributes(html_options.except(:class)) %>>
  <div class="flex items-center px-5 h-16 w-full max-w-7xl mx-auto justify-between">
    <div class="flex items-center gap-4 min-w-0">
      <% if back_href.present? %>
        <a href="<%= back_href %>"
           data-back-fallback="<%= back_href %>"
           onclick="if(history.length>1){history.back();return false;}"
           class="p-2 -ml-2 rounded-full hover:bg-surface-container-low dark:hover:bg-gray-800 transition-colors active:scale-95 duration-200 shrink-0">
          <%= render Ui::IconComponent.new(name: back_icon, size_class: "text-black dark:text-white text-2xl") %>
        </a>
      <% end %>
      <a href="/" class="block font-lexend font-bold tracking-tight text-lg text-black dark:text-white uppercase leading-none truncate">
        <%= title %>
      </a>
    </div>
    <% if trailing.present? %>
      <div class="flex items-center shrink-0">
        <%= trailing %>
      </div>
    <% end %>
  </div>
</header>
