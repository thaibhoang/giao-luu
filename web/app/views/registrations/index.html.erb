<% content_for :title, "Người đăng ký — #{@listing.title} | SportMatch" %>

<%= render Ui::TopAppBarComponent.new(title: "Người đăng ký", back_href: listing_path(@listing)) %>

<div class="pt-20 pb-10 px-5 max-w-3xl mx-auto space-y-6">
  <div class="space-y-1">
    <h2 class="text-xl font-extrabold text-on-surface"><%= @listing.title %></h2>
    <div class="flex gap-3 text-sm text-on-surface-variant flex-wrap">
      <span><%= @registrations.size %> đơn tổng cộng</span>
      <% if @pending_count > 0 %>
        <span class="font-semibold text-amber-600">· <%= @pending_count %> chờ duyệt</span>
      <% end %>
      <span class="text-green-600">· <%= @accepted_count %> đã chấp nhận</span>
    </div>
  </div>

  <% if @registrations.empty? %>
    <div class="py-16 flex flex-col items-center gap-3 text-on-surface-variant">
      <%= render Ui::IconComponent.new(name: "group", size_class: "text-5xl opacity-30") %>
      <p class="text-sm">Chưa có ai đăng ký tham gia bài đăng này.</p>
    </div>
  <% else %>
    <%# Nhóm pending trước %>
    <% pending_regs  = @registrations.select(&:pending?) %>
    <% accepted_regs = @registrations.select(&:accepted?) %>
    <% rejected_regs = @registrations.select(&:rejected?) %>

    <% if pending_regs.any? %>
      <div>
        <h3 class="text-[10px] font-bold tracking-widest uppercase text-amber-600 mb-3">⏳ Chờ duyệt (<%= pending_regs.size %>)</h3>
        <ul class="space-y-3">
          <% pending_regs.each_with_index do |reg, idx| %>
            <%= render "registrations/registration_item", reg: reg, idx: idx, listing: @listing %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if accepted_regs.any? %>
      <div>
        <h3 class="text-[10px] font-bold tracking-widest uppercase text-green-600 mb-3">✅ Đã chấp nhận (<%= accepted_regs.size %>)</h3>
        <ul class="space-y-3">
          <% accepted_regs.each_with_index do |reg, idx| %>
            <%= render "registrations/registration_item", reg: reg, idx: idx, listing: @listing %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if rejected_regs.any? %>
      <div>
        <h3 class="text-[10px] font-bold tracking-widest uppercase text-on-surface-variant mb-3 opacity-50">✗ Đã từ chối (<%= rejected_regs.size %>)</h3>
        <ul class="space-y-3 opacity-60">
          <% rejected_regs.each_with_index do |reg, idx| %>
            <%= render "registrations/registration_item", reg: reg, idx: idx, listing: @listing %>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>
