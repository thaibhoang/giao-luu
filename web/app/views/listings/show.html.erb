<% content_for :title, "#{@listing.title} | SportMatch" %>
<% content_for :head do %>
  <meta name="description" content="<%= listing_meta_description(@listing) %>">
  <link rel="canonical" href="<%= listing_url(@listing) %>">

  <%# Open Graph — Facebook / Zalo share preview %>
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="SportMatch">
  <meta property="og:title"       content="<%= @listing.title %>">
  <meta property="og:description" content="<%= listing_meta_description(@listing) %>">
  <meta property="og:url"         content="<%= listing_url(@listing) %>">
  <meta property="og:image"       content="<%= listing_og_image_url(@listing) %>">
  <meta property="og:locale"      content="vi_VN">

  <%# Twitter Card %>
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= @listing.title %>">
  <meta name="twitter:description" content="<%= listing_meta_description(@listing) %>">
  <meta name="twitter:image"       content="<%= listing_og_image_url(@listing) %>">

  <%= structured_data_tag(@listing, lat: @listing_lat, lng: @listing_lng, url: listing_url(@listing)) %>

  <%# preload Google Maps JS chỉ khi listing có tọa độ — tránh load trên trang không dùng map %>
  <% if @listing_lat.present? && @listing_lng.present? && ENV["GOOGLE_MAPS_API_KEY"].present? %>
    <link rel="preload" href="https://maps.googleapis.com/maps/api/js?key=<%= ENV["GOOGLE_MAPS_API_KEY"] %>" as="script">
  <% end %>
<% end %>

<%= render Ui::TopAppBarComponent.new(title: "Match details", back_href: map_path) do |bar| %>
  <% bar.with_trailing do %>
    <% if authenticated? %>
      <%= turbo_frame_tag dom_id(@listing, :show_bookmark) do %>
        <% if @bookmarked %>
          <%= button_to listing_bookmark_path(@listing), method: :delete,
                data: { turbo_stream: true, turbo_frame: "_top" },
                class: "p-2 rounded-full hover:bg-amber-50 text-amber-500" do %>
            <%= render Ui::IconComponent.new(name: "bookmark") %>
          <% end %>
        <% else %>
          <%= button_to listing_bookmark_path(@listing), method: :post,
                data: { turbo_stream: true, turbo_frame: "_top" },
                class: "p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant" do %>
            <%= render Ui::IconComponent.new(name: "bookmark_border") %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
    <button type="button" class="p-2 rounded-full hover:bg-surface-container-low">
      <%= render Ui::IconComponent.new(name: "share") %>
    </button>
  <% end %>
<% end %>

<article class="pt-20 pb-28 px-5 max-w-3xl mx-auto space-y-8">
  <section class="space-y-4">
    <div class="flex flex-wrap gap-2">
      <%= render Ui::BadgeComponent.new(@listing.source == Listing::SOURCE_USER_SUBMITTED ? "Người dùng đăng" : "Từ scraper", tone: :neutral) %>
      <%
        badge_tone = case @listing.listing_type
                     when "court_pass" then :warning
                     when "tournament" then :info
                     else :success
                     end
      %>
      <%= render Ui::BadgeComponent.new(@listing.listing_type_label, tone: badge_tone) %>
      <% if listing_rain_warning?(@listing) %>
        <%= render Ui::BadgeComponent.new("⚠️ Có thể mưa", tone: :warning) %>
      <% end %>
    </div>
    <h1 class="text-3xl font-extrabold leading-tight tracking-tight text-primary"><%= @listing.title %></h1>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="flex items-start gap-3"><%= render Ui::SportIconComponent.new(sport: @listing.sport, class: "w-6 h-6 mt-0.5 flex-shrink-0") %> <div><p class="text-xs uppercase text-on-surface-variant font-bold">Môn</p><p><%= @listing.sport.humanize %></p></div></div>
    <div class="flex items-start gap-3"><%= render Ui::IconComponent.new(name: "location_on") %> <div><p class="text-xs uppercase text-on-surface-variant font-bold">Địa điểm</p><p><%= @listing.location_name %></p></div></div>
    <div class="flex items-start gap-3"><%= render Ui::IconComponent.new(name: "schedule") %> <div><p class="text-xs uppercase text-on-surface-variant font-bold">Thời gian</p><p><%= l(@listing.start_at, format: :long) %> - <%= l(@listing.end_at, format: :short) %></p></div></div>
    <% unless @listing.court_pass? %>
    <div class="flex items-start gap-3"><%= render Ui::IconComponent.new(name: "person_add") %> <div><p class="text-xs uppercase text-on-surface-variant font-bold">Cần thêm</p><p><%= @listing.slots_needed %> người</p></div></div>
    <div class="flex items-start gap-3"><%= render Ui::IconComponent.new(name: "trending_up") %> <div><p class="text-xs uppercase text-on-surface-variant font-bold">Trình độ</p><p><%= @listing.skill_range_label %></p></div></div>
    <% end %>
    <% unless @listing.court_pass? %>
    <div class="flex items-start gap-3"><%= render Ui::IconComponent.new(name: "payments") %> <div><p class="text-xs uppercase text-on-surface-variant font-bold">Giá</p><p><%= number_with_delimiter(@listing.price_estimate || 0) %> VND</p></div></div>
    <% end %>
  </section>

  <% has_coordinates = @listing_lat.present? && @listing_lng.present? %>
  <section class="relative h-44 rounded-3xl bg-surface-container-high overflow-hidden">
    <% if has_coordinates && ENV["GOOGLE_MAPS_API_KEY"].present? %>
      <div
        id="listing-detail-map"
        class="absolute inset-0"
        data-lat="<%= @listing_lat %>"
        data-lng="<%= @listing_lng %>"
      ></div>
      <a href="<%= map_path(lat: @listing_lat, lng: @listing_lng, listing_id: @listing.id) %>" class="absolute bottom-4 right-4 bg-white px-4 py-2 rounded-full shadow-sm text-xs font-bold uppercase hover:bg-surface-container-low transition-colors">Bản đồ</a>
    <% elsif has_coordinates %>
      <div class="absolute inset-0 p-4 text-sm text-amber-900 bg-amber-50 border border-amber-300">
        Thiếu cấu hình <code>GOOGLE_MAPS_API_KEY</code>, chưa thể hiển thị bản đồ.
      </div>
    <% else %>
      <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle, #000 1px, transparent 1px); background-size: 20px 20px;"></div>
      <div class="absolute inset-0 flex items-center justify-center text-xs font-semibold text-on-surface-variant">
        Listing chưa có tọa độ bản đồ
      </div>
    <% end %>
  </section>

  <section class="space-y-3">
    <h3 class="text-[10px] font-bold text-on-surface-variant tracking-[0.2em] uppercase">Mô tả chi tiết</h3>
    <div class="p-6 bg-surface-container-lowest border border-outline-variant/10 rounded-3xl">
      <p class="text-on-surface leading-relaxed"><%= @listing.body.presence || "Không có mô tả thêm." %></p>
    </div>
  </section>

  <% if @listing.court_pass? && (d = @listing.court_pass_detail) %>
  <section class="space-y-3">
    <h3 class="text-[10px] font-bold text-on-surface-variant tracking-[0.2em] uppercase">🏟️ Thông tin Pass sân</h3>
    <div class="p-6 bg-surface-container-lowest border border-outline-variant/10 rounded-3xl space-y-3">
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Tên sân</span>
        <span class="font-semibold text-on-surface"><%= d.court_name %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Giá gốc</span>
        <span class="font-semibold text-on-surface line-through text-on-surface-variant"><%= number_with_delimiter(d.original_price) %> VND</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Giá nhượng</span>
        <span class="font-bold text-primary text-base"><%= number_with_delimiter(d.pass_price) %> VND</span>
      </div>
      <% if d.booking_proof.present? %>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Xác nhận đặt sân</span>
        <a href="<%= d.booking_proof %>" target="_blank" rel="noopener noreferrer"
           class="text-primary font-semibold underline">Xem link</a>
      </div>
      <% end %>
    </div>
  </section>
  <% end %>

  <% if @listing.tournament? && (d = @listing.tournament_detail) %>
  <section class="space-y-3">
    <h3 class="text-[10px] font-bold text-on-surface-variant tracking-[0.2em] uppercase">🏆 Thông tin giải đấu</h3>
    <div class="p-6 bg-surface-container-lowest border border-outline-variant/10 rounded-3xl space-y-3">
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Tên giải</span>
        <span class="font-bold text-on-surface"><%= d.tournament_name %></span>
      </div>
      <% if d.organizer.present? %>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Đơn vị tổ chức</span>
        <span class="font-semibold text-on-surface"><%= d.organizer %></span>
      </div>
      <% end %>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Hạn đăng ký</span>
        <span class="font-semibold text-on-surface"><%= l(d.registration_deadline, format: :long) %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Thể thức</span>
        <span class="font-semibold text-on-surface"><%= TournamentDetail::FORMAT_LABELS.fetch(d.format, d.format) %></span>
      </div>
      <% if d.prize_info.present? %>
      <div class="flex justify-between text-sm">
        <span class="text-on-surface-variant font-medium">Giải thưởng</span>
        <span class="font-semibold text-on-surface"><%= d.prize_info %></span>
      </div>
      <% end %>
      <% if d.registration_link.present? %>
      <div class="pt-1">
        <a href="<%= d.registration_link %>" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 text-sm text-primary font-bold underline">
          Đăng ký tham gia chính thức →
        </a>
      </div>
      <% end %>
    </div>
  </section>
  <% end %>

  <section class="space-y-3 pb-10">
    <a class="inline-flex items-center gap-2 text-primary font-bold text-sm border-b border-surface-variant pb-1" href="<%= @listing.contact_info %>">Xem thêm thông tin liên hệ</a>
    <%# Link đến profile công khai của chủ tin %>
    <% if @listing.user.present? %>
      <%= link_to public_user_profile_path(@listing.user),
            class: "flex items-center gap-3 p-3 bg-surface-container-low rounded-2xl hover:bg-surface-container transition-colors",
            data: { turbo_frame: "_top" } do %>
        <% gravatar_hash = Digest::MD5.hexdigest(@listing.user.email_address.downcase.strip) %>
        <img src="https://www.gravatar.com/avatar/<%= gravatar_hash %>?s=64&d=identicon"
             alt="<%= @listing.user.name_or_email %>"
             class="w-10 h-10 rounded-full bg-primary/10 object-cover shrink-0">
        <div class="min-w-0 flex-1">
          <p class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold">Chủ tin</p>
          <p class="font-semibold text-on-surface text-sm truncate"><%= @listing.user.name_or_email %></p>
        </div>
        <% pts = @listing.user.reputation_points %>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold shrink-0
          <%= pts > 0 ? 'bg-green-100 text-green-700' : 'bg-surface-container text-on-surface-variant' %>">
          <%= render Ui::IconComponent.new(name: "military_tech", size_class: "text-sm") %>
          <%= pts %> điểm
        </span>
      <% end %>
    <% end %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <%= render Ui::ButtonComponent.new(
        "Mở trong bản đồ",
        variant: :secondary,
        icon: "directions",
        icon_position: :leading,
        full_width: true,
        href: map_path(lat: @listing_lat, lng: @listing_lng, listing_id: @listing.id)
      ) %>
      <%= render Ui::ButtonComponent.new("Sao chép liên kết", variant: :secondary, icon: "content_copy", icon_position: :leading, full_width: true) %>
    </div>
  </section>

  <%= render "listings/chat_panel" %>

  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "SportsEvent",
      name: @listing.title,
      startDate: @listing.start_at&.iso8601,
      endDate: @listing.end_at&.iso8601,
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: {
        "@type": "Place",
        name: @listing.location_name
      },
      description: @listing.body.to_s,
      url: listing_url(@listing)
    }.to_json) %>
  </script>
</article>

<% if @listing_lat.present? && @listing_lng.present? && ENV["GOOGLE_MAPS_API_KEY"].present? %>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= ENV["GOOGLE_MAPS_API_KEY"] %>" defer></script>
  <script>
    (() => {
      if (window.__sportMatchListingDetailMapBound) return;
      window.__sportMatchListingDetailMapBound = true;

      const waitForGoogle = () =>
        new Promise((resolve, reject) => {
          const startedAt = Date.now();
          const timer = setInterval(() => {
            if (window.google && window.google.maps) {
              clearInterval(timer);
              resolve();
            } else if (Date.now() - startedAt > 12_000) {
              clearInterval(timer);
              reject(new Error("Google Maps library timeout"));
            }
          }, 120);
        });

      const initDetailMap = async () => {
        const mapEl = document.getElementById("listing-detail-map");
        if (!mapEl) return;
        if (mapEl.dataset.initialized === "true") return;
        mapEl.dataset.initialized = "true";

        await waitForGoogle();

        const center = {
          lat: Number(mapEl.dataset.lat),
          lng: Number(mapEl.dataset.lng)
        };

        const map = new google.maps.Map(mapEl, {
          center,
          zoom: 15,
          mapTypeControl: false,
          streetViewControl: false,
          fullscreenControl: false
        });

        new google.maps.Marker({
          map,
          position: center,
          title: "<%= j @listing.title %>"
        });
      };

      document.addEventListener("turbo:load", () => {
        initDetailMap().catch((error) => {
          console.error("Khong khoi tao duoc map detail", error);
        });
      });
    })();
  </script>
<% end %>

<%= render Ui::FixedBottomBarComponent.new(with_border: true, inner_class: "max-w-3xl mx-auto px-5") do %>
  <%
    is_owner     = current_user && @listing.user_id == current_user.id
    is_fb_scrape = @listing.source == Listing::SOURCE_FACEBOOK_SCRAPE
    already_registered = current_user && @listing.registrations.exists?(user: current_user)
  %>

  <% if is_owner %>
    <%# Chủ bài: xem danh sách người đăng ký %>
    <%= render Ui::ButtonComponent.new(
      "Xem người đăng ký (#{@listing.registrations.count})",
      full_width: true,
      icon: "group",
      icon_position: :leading,
      href: listing_registrations_path(@listing)
    ) %>

  <% elsif is_fb_scrape %>
    <%# Bài từ admin / scraper: không hỗ trợ đăng ký trực tiếp %>
    <a href="<%= @listing.contact_info %>" target="_blank" rel="noopener noreferrer"
       class="flex items-center justify-center gap-2 w-full h-14 px-5 text-base bg-primary text-on-primary-container font-lexend font-bold rounded-xl hover:opacity-90 active:scale-[0.98] shadow-xl shadow-black/10">
      <%= render Ui::IconComponent.new(name: "open_in_new", size_class: "text-xl") %>
      Liên hệ qua Facebook
    </a>

  <% elsif current_user.nil? %>
    <%# Chưa đăng nhập %>
    <%= render Ui::ButtonComponent.new(
      "Đăng nhập để đăng ký tham gia",
      full_width: true,
      icon: "login",
      icon_position: :leading,
      href: new_session_path
    ) %>

  <% elsif already_registered %>
    <%
      my_reg        = @listing.registrations.find_by(user: current_user)
      ended         = @listing.end_at <= Time.current
      can_checkin   = ended && my_reg&.accepted? && my_reg&.checked_in_at.nil?
      checked_in    = my_reg&.checked_in_at.present?
    %>
    <div class="flex gap-3">
      <% if my_reg&.pending? %>
        <span class="flex-1 flex items-center justify-center gap-2 h-14 px-5 rounded-xl bg-amber-50 border border-amber-200 text-amber-700 text-sm font-semibold">
          <%= render Ui::IconComponent.new(name: "pending", size_class: "text-xl") %>
          Chờ chủ tin duyệt…
        </span>
      <% elsif my_reg&.rejected? %>
        <span class="flex-1 flex items-center justify-center gap-2 h-14 px-5 rounded-xl bg-red-50 border border-red-200 text-red-600 text-sm font-semibold">
          <%= render Ui::IconComponent.new(name: "cancel", size_class: "text-xl") %>
          Đơn bị từ chối
        </span>
      <% elsif can_checkin %>
        <%# Sau end_at — hiện nút check-in %>
        <%= button_to(
          checkin_listing_registration_path(@listing, my_reg),
          method: :put,
          class: "flex-1 flex items-center justify-center gap-2 h-14 px-5 rounded-xl bg-primary text-on-primary-container font-lexend font-bold text-sm hover:opacity-90 active:scale-[0.98]"
        ) do %>
          <%= render Ui::IconComponent.new(name: "where_to_vote", size_class: "text-xl") %>
          Check-in
        <% end %>
      <% elsif checked_in %>
        <span class="flex-1 flex items-center justify-center gap-2 h-14 px-5 rounded-xl bg-surface-container-high border border-outline-variant text-on-surface-variant text-sm font-semibold">
          <%= render Ui::IconComponent.new(name: "where_to_vote", size_class: "text-xl text-green-600") %>
          Đã check-in
        </span>
      <% else %>
        <span class="flex-1 flex items-center justify-center gap-2 h-14 px-5 rounded-xl bg-surface-container-high border border-outline-variant text-on-surface-variant text-sm font-semibold">
          <%= render Ui::IconComponent.new(name: "check_circle", size_class: "text-xl text-green-600") %>
          Đã được chấp nhận
        </span>
      <% end %>
      <% unless my_reg&.rejected? %>
        <%= button_to(
          listing_registration_path(@listing, my_reg),
          method: :delete,
          class: "h-14 px-5 rounded-xl bg-surface-container-high border border-outline-variant text-on-surface-variant text-sm font-semibold hover:bg-surface-container-highest flex items-center gap-2",
          disabled: checked_in || ended
        ) do %>
          <%= render Ui::IconComponent.new(name: "close", size_class: "text-xl") %>
          Huỷ
        <% end %>
      <% end %>
    </div>

  <% else %>
    <%# Chưa đăng ký — hiển thị form %>
    <details class="group">
      <summary class="list-none cursor-pointer">
        <div class="flex items-center justify-center gap-2 w-full h-14 px-5 text-base bg-primary text-on-primary-container font-lexend font-bold rounded-xl hover:opacity-90 active:scale-[0.98] shadow-xl shadow-black/10 group-open:rounded-b-none group-open:rounded-t-xl select-none">
          <%= render Ui::IconComponent.new(name: "how_to_reg", size_class: "text-xl") %>
          Đăng ký tham gia
        </div>
      </summary>

      <%= form_with url: listing_registrations_path(@listing), method: :post,
                    class: "p-4 bg-surface-container-lowest border border-t-0 border-outline-variant/20 rounded-b-2xl space-y-3" do |f| %>
        <div>
          <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-wide mb-1">
            Ghi chú (tuỳ chọn)
          </label>
          <%= f.text_area :note,
            placeholder: "Trình độ, lịch rảnh, câu hỏi…",
            rows: 2,
            class: "w-full rounded-xl border border-outline-variant bg-surface px-4 py-2 text-sm text-on-surface placeholder:text-on-surface-variant focus:outline-none focus:ring-2 focus:ring-primary resize-none",
            name: "registration[note]" %>
        </div>
        <div>
          <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-wide mb-1">
            SĐT liên hệ (tuỳ chọn)
          </label>
          <%= f.telephone_field :phone,
            placeholder: "0901 234 567",
            class: "w-full rounded-xl border border-outline-variant bg-surface px-4 py-2 text-sm text-on-surface placeholder:text-on-surface-variant focus:outline-none focus:ring-2 focus:ring-primary",
            name: "registration[phone]" %>
        </div>
        <%= f.submit "Xác nhận đăng ký",
          class: "w-full h-12 bg-primary text-on-primary-container font-bold rounded-xl hover:opacity-90 cursor-pointer text-sm" %>
      <% end %>
    </details>
  <% end %>
<% end %>
