<%# Results bottom panel %>
<div data-browse-map-target="panel"
  class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-2xl rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.08)] z-20 transition-transform duration-300 ease-out translate-y-full"
  style="height:300px">

  <%# Drag handle / collapse button %>
  <div class="flex justify-center pt-2 pb-1">
    <button type="button"
      data-browse-map-target="panelToggle"
      data-action="click->browse-map#togglePanel"
      aria-expanded="false"
      class="w-16 h-5 inline-flex items-center justify-center rounded-full hover:bg-black/5">
      <span class="w-10 h-1.5 bg-outline-variant rounded-full"></span>
      <span class="sr-only">Ẩn danh sách kèo</span>
    </button>
  </div>

  <%# Tab bar %>
  <div class="px-5 flex items-center gap-1 border-b border-outline-variant/20 mb-0">
    <button type="button"
      data-browse-map-target="tabListBtn"
      data-action="click->browse-map#switchToList"
      class="px-4 py-2 text-sm font-semibold border-b-2 border-primary text-primary transition-colors">
      Kèo quanh đây
    </button>
    <button type="button"
      data-browse-map-target="tabDetailBtn"
      data-action="click->browse-map#switchToDetail"
      class="px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant transition-colors">
      Chi tiết sân
    </button>
    <span class="flex-1"></span>
    <p data-browse-map-target="resultCount"
      class="text-on-surface-variant text-xs pr-1">Tìm thấy <%= @listings.size %> trận đấu</p>
  </div>

  <%# Tab: Kèo quanh đây %>
  <div data-browse-map-target="tabListContent"
    class="h-[calc(100%-88px)] overflow-hidden">
    <div data-browse-map-target="resultList"
      class="flex gap-4 overflow-x-auto px-5 pt-3 pb-6 h-full">
    </div>
  </div>

  <%# Tab: Chi tiết sân %>
  <div data-browse-map-target="tabDetailContent"
    class="hidden h-[calc(100%-88px)] overflow-y-auto px-5 pt-3 pb-6">
    <p class="text-sm text-on-surface-variant">Bấm vào một sân trên bản đồ để xem chi tiết.</p>
  </div>
</div>

<%# Nút mở rộng panel — hiện khi panel ẩn %>
<button type="button"
  data-browse-map-target="panelExpand"
  data-action="click->browse-map#expandPanel"
  class="absolute left-1/2 -translate-x-1/2 bottom-4 z-20 w-10 h-10 bg-white/95 backdrop-blur-xl rounded-full shadow-md border border-outline-variant/20 flex items-center justify-center text-primary transition-opacity duration-200">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 8l-6 6 1.41 1.41L12 10.83l4.59 4.58L18 14z"/>
  </svg>
  <span class="sr-only">Mở danh sách kèo</span>
</button>
