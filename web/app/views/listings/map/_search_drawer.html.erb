<%# Search Drawer backdrop %>
<div data-browse-map-target="drawerBackdrop"
  data-action="click->browse-map#closeDrawer"
  class="fixed inset-0 bg-black/30 backdrop-blur-sm z-30 hidden transition-opacity duration-300 opacity-0">
</div>

<%# Search Drawer %>
<div data-browse-map-target="drawer"
  class="fixed top-0 left-0 h-full w-[90vw] md:w-1/2 bg-white z-40 shadow-2xl flex flex-col transition-transform duration-300 ease-out -translate-x-full"
  style="max-width: 480px">

  <%# Header %>
  <div class="flex items-center justify-between px-5 pt-5 pb-4 border-b border-outline-variant/20 flex-shrink-0">
    <h2 class="text-base font-semibold text-on-surface">Tìm kiếm kèo</h2>
    <button type="button"
      data-action="click->browse-map#closeDrawer"
      class="w-8 h-8 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-container transition-colors">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
  </div>

  <%# Body — scrollable %>
  <div class="flex-1 overflow-y-auto px-5 py-4 space-y-6">

    <%# Listing type %>
    <div>
      <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Loại tin</p>
      <div class="flex flex-wrap gap-2">
        <% ([["Tất cả", ""]] + Listing::LISTING_TYPE_LABELS.to_a).each do |label, value| %>
          <button type="button"
            data-browse-map-target="listingTypeBtn" data-listing-type="<%= value %>"
            data-action="click->browse-map#selectListingType"
            class="px-4 h-9 rounded-full text-sm font-semibold border transition-colors
                   <%= value == 'match_finding' ? 'bg-primary text-white border-primary' : 'bg-white text-on-surface border-outline-variant/40' %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Sport %>
    <div>
      <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Bộ môn</p>
      <div class="flex gap-2">
        <button type="button"
          data-browse-map-target="sportBtn" data-sport=""
          data-action="click->browse-map#selectSport"
          class="px-4 h-9 rounded-full text-sm font-semibold border transition-colors bg-primary text-white border-primary">
          Tất cả
        </button>
        <button type="button"
          data-browse-map-target="sportBtn" data-sport="badminton"
          data-action="click->browse-map#selectSport"
          class="px-4 h-9 rounded-full text-sm font-semibold border transition-colors bg-white text-on-surface border-outline-variant/40">
          🏸 Cầu lông
        </button>
        <button type="button"
          data-browse-map-target="sportBtn" data-sport="pickleball"
          data-action="click->browse-map#selectSport"
          class="px-4 h-9 rounded-full text-sm font-semibold border transition-colors bg-white text-on-surface border-outline-variant/40">
          🏓 Pickleball
        </button>
      </div>
    </div>

    <%# Keyword %>
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2" for="drawer-q">
        Từ khoá
      </label>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor">
          <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
        <input id="drawer-q" type="text" placeholder="Tên kèo, địa điểm..."
          data-browse-map-target="qInput"
          class="w-full h-10 pl-9 pr-3 rounded-xl border border-outline-variant/30 bg-surface-container-low text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
      </div>
    </div>

    <%# Time range %>
    <div>
      <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Thời gian</p>
      <div class="grid grid-cols-2 gap-3">
        <label>
          <span class="block text-[11px] text-on-surface-variant mb-1">Từ</span>
          <input id="drawer-from" type="datetime-local"
            data-browse-map-target="fromInput"
            class="w-full h-10 rounded-xl border border-outline-variant/30 bg-surface-container-low px-3 text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
        </label>
        <label>
          <span class="block text-[11px] text-on-surface-variant mb-1">Đến</span>
          <input id="drawer-to" type="datetime-local"
            data-browse-map-target="toInput"
            class="w-full h-10 rounded-xl border border-outline-variant/30 bg-surface-container-low px-3 text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
        </label>
      </div>
    </div>

    <%# Skill level %>
    <div>
      <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Trình độ</p>
      <div class="grid grid-cols-2 gap-3">
        <label>
          <span class="block text-[11px] text-on-surface-variant mb-1">Tối thiểu</span>
          <select id="drawer-skill-min" data-browse-map-target="skillMin"
            class="w-full h-10 rounded-xl border border-outline-variant/30 bg-surface-container-low px-3 text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors appearance-none"
            data-badminton-options="<%= Listing::SKILL_LEVELS.map { |s| [Listing::SKILL_LEVEL_LABELS[s], s] }.to_json %>"
            data-pickleball-options="<%= Listing::SKILL_LEVELS_PK.map { |s| [Listing::SKILL_LEVEL_PK_LABELS[s], s] }.to_json %>">
            <option value="yeu">Yếu</option>
            <option value="trung_binh_yeu">Trung bình yếu</option>
            <option value="trung_binh_minus">Trung bình -</option>
            <option value="trung_binh">Trung bình</option>
            <option value="trung_binh_plus">Trung bình +</option>
            <option value="trung_binh_plus_plus">Trung bình ++</option>
            <option value="trung_binh_kha">Trung bình khá</option>
            <option value="kha">Khá</option>
            <option value="ban_chuyen">Bán chuyên</option>
            <option value="chuyen_nghiep">Chuyên nghiệp</option>
          </select>
        </label>
        <label>
          <span class="block text-[11px] text-on-surface-variant mb-1">Tối đa</span>
          <select id="drawer-skill-max" data-browse-map-target="skillMax"
            class="w-full h-10 rounded-xl border border-outline-variant/30 bg-surface-container-low px-3 text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors appearance-none"
            data-badminton-options="<%= Listing::SKILL_LEVELS.map { |s| [Listing::SKILL_LEVEL_LABELS[s], s] }.to_json %>"
            data-pickleball-options="<%= Listing::SKILL_LEVELS_PK.map { |s| [Listing::SKILL_LEVEL_PK_LABELS[s], s] }.to_json %>">
            <option value="yeu">Yếu</option>
            <option value="trung_binh_yeu">Trung bình yếu</option>
            <option value="trung_binh_minus">Trung bình -</option>
            <option value="trung_binh">Trung bình</option>
            <option value="trung_binh_plus">Trung bình +</option>
            <option value="trung_binh_plus_plus">Trung bình ++</option>
            <option value="trung_binh_kha">Trung bình khá</option>
            <option value="kha">Khá</option>
            <option value="ban_chuyen">Bán chuyên</option>
            <option value="chuyen_nghiep" selected>Chuyên nghiệp</option>
          </select>
        </label>
      </div>
    </div>

    <%# Location radius %>
    <div>
      <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Tìm theo khu vực</p>
      <div class="mb-3">
        <span class="block text-[11px] text-on-surface-variant mb-1">Bán kính (km)</span>
        <div class="flex gap-2">
          <button type="button"
            data-browse-map-target="radiusBtn" data-radius="3"
            data-action="click->browse-map#selectRadius"
            class="flex-1 h-9 rounded-xl border text-sm font-semibold transition-colors bg-primary text-white border-primary">3 km</button>
          <button type="button"
            data-browse-map-target="radiusBtn" data-radius="5"
            data-action="click->browse-map#selectRadius"
            class="flex-1 h-9 rounded-xl border text-sm font-semibold transition-colors bg-white text-on-surface border-outline-variant/40">5 km</button>
          <button type="button"
            data-browse-map-target="radiusBtn" data-radius="10"
            data-action="click->browse-map#selectRadius"
            class="flex-1 h-9 rounded-xl border text-sm font-semibold transition-colors bg-white text-on-surface border-outline-variant/40">10 km</button>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <button type="button"
          data-browse-map-target="useLocationBtn"
          data-action="click->browse-map#useLocation"
          class="h-10 rounded-xl border border-outline-variant/30 bg-surface-container-low text-xs font-semibold text-on-surface flex items-center justify-center gap-1.5 hover:bg-surface-container transition-colors">
          <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/>
          </svg>
          Vị trí của tôi
        </button>
        <button type="button"
          data-action="click->browse-map#enterPinMode"
          class="h-10 rounded-xl border border-outline-variant/30 bg-surface-container-low text-xs font-semibold text-on-surface flex items-center justify-center gap-1.5 hover:bg-surface-container transition-colors">
          <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          Pin trên bản đồ
        </button>
      </div>
      <%# Location status badge %>
      <div data-browse-map-target="locationStatus"
        class="hidden mt-2 flex items-center gap-2 px-3 py-2 rounded-xl bg-primary/8 border border-primary/20">
        <svg class="w-3.5 h-3.5 text-primary flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <span data-browse-map-target="locationStatusText"
          class="text-xs text-primary font-medium flex-1 truncate"></span>
        <button type="button"
          data-action="click->browse-map#clearLocation"
          class="text-on-surface-variant hover:text-on-surface">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <%# Footer — submit %>
  <div class="flex-shrink-0 px-5 py-4 border-t border-outline-variant/20">
    <button type="button"
      data-action="click->browse-map#doSearch"
      class="w-full h-11 bg-primary text-white rounded-xl font-semibold text-sm flex items-center justify-center gap-2 hover:bg-primary/90 active:scale-[0.98] transition-all">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
      </svg>
      Tìm kiếm
    </button>
  </div>
</div>
