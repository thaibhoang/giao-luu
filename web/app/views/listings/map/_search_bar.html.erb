<%# Floating search bar trigger %>
<div class="relative z-10 px-4 pt-4">
  <button type="button"
    data-action="click->browse-map#openDrawer"
    class="w-full md:w-1/3 lg:w-1/3 flex items-center gap-3 h-12 bg-white/95 backdrop-blur-xl rounded-2xl shadow-md border border-outline-variant/20 px-4 text-left">
    <svg class="w-4 h-4 text-on-surface-variant flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
      <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
    </svg>
    <span data-browse-map-target="searchBarLabel"
      class="flex-1 text-sm text-on-surface-variant truncate">Tìm kiếm kèo...</span>
    <svg class="w-4 h-4 text-on-surface-variant flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 18h6v-2H3v2zm0-5h12v-2H3v2zm0-7v2h18V6H3z"/>
    </svg>
  </button>
</div>
