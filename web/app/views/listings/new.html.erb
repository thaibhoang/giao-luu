<% content_for :title, "Đăng tin mới | SportMatch" %>

<%= render Ui::TopAppBarComponent.new(title: "Đăng tin mới", back_href: listings_path, back_icon: "close") do |bar| %>
  <% bar.with_trailing do %>
    <%= render Ui::BadgeComponent.new("Bản nháp", tone: :neutral) %>
  <% end %>
<% end %>

<%= render Ui::PageShellComponent.new(padding_top: "pt-24", max_width: "max-w-2xl", horizontal_padding: "px-5", padding_bottom: "pb-32") do %>
  <section class="mb-6">
    <p class="text-on-surface-variant text-sm leading-relaxed max-w-sm">
      Hoàn thành các thông tin bên dưới để tìm đối thủ hoặc đồng đội phù hợp nhất.
    </p>
  </section>

  <%= render "form", listing: @listing, url: listings_path, method: :post, submit_label: "Đăng tin", submit_icon: "send", lat_value: params.dig(:listing, :lat), lng_value: params.dig(:listing, :lng) %>
<% end %>
