<% content_for :title, "Bản đồ kèo | SportMatch" %>
<% content_for :head do %>
  <link rel="canonical" href="<%= map_url %>">
  <%# preload Maps JS — chỉ trên trang map, tránh load ở trang không dùng %>
  <% if ENV["GOOGLE_MAPS_API_KEY"].present? %>
    <link rel="preload" href="https://maps.googleapis.com/maps/api/js?key=<%= ENV["GOOGLE_MAPS_API_KEY"] %>" as="script">
    <link rel="preload" href="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js" as="script">
  <% end %>
<% end %>

<%= render Ui::TopAppBarComponent.new(title: "SportMatch") do |bar| %>
  <% bar.with_trailing do %>
    <%= link_to my_listings_path, class: "w-8 h-8 rounded-full border border-outline-variant overflow-hidden flex items-center justify-center" do %>
      <%= render Ui::IconComponent.new(name: "person", size_class: "text-base") %>
    <% end %>
  <% end %>
<% end %>

<div class="pt-16 pb-24 relative min-h-screen"
  data-controller="browse-map"
  data-browse-map-initial-lat-value="<%= @map_center_lat %>"
  data-browse-map-initial-lng-value="<%= @map_center_lng %>"
  data-browse-map-focus-listing-id-value="<%= @map_focus_listing_id %>"
  data-browse-map-badminton-asset-value="<%= asset_path('badminton_pin.svg') %>"
  data-browse-map-pickleball-asset-value="<%= asset_path('pickleball_pin.svg') %>">

  <%# Map canvas %>
  <div data-browse-map-target="mapCanvas"
    class="absolute inset-0 bg-surface-container-low"></div>

  <%= render "listings/map/search_bar" %>
  <%= render "listings/map/search_drawer" %>
  <%= render "listings/map/pin_mode_overlays" %>
  <%= render "listings/map/results_panel" %>
</div>

<% if ENV["GOOGLE_MAPS_API_KEY"].present? %>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= ENV["GOOGLE_MAPS_API_KEY"] %>" defer></script>
  <script src="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js" defer></script>
<% else %>
  <div class="fixed top-20 left-1/2 -translate-x-1/2 z-40 w-[92%] max-w-xl rounded-2xl border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900 shadow">
    Thiếu cấu hình <code>GOOGLE_MAPS_API_KEY</code>. Vui lòng thêm key vào file <code>.env</code> ở thư mục gốc và khởi động lại Docker để hiển thị bản đồ.
  </div>
<% end %>
