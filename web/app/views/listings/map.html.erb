<% content_for :title, "Bản đồ kèo | SportMatch" %>

<%= render Ui::TopAppBarComponent.new(title: "SportMatch") do |bar| %>
  <% bar.with_trailing do %>
    <%= link_to my_listings_path, class: "w-8 h-8 rounded-full border border-outline-variant overflow-hidden flex items-center justify-center" do %>
      <%= render Ui::IconComponent.new(name: "person", size_class: "text-base") %>
    <% end %>
  <% end %>
<% end %>

<div class="pt-16 pb-24 relative min-h-screen">
  <div
    id="browse-map"
    class="absolute inset-0 bg-surface-container-low"
    data-initial-lat="<%= @map_center_lat %>"
    data-initial-lng="<%= @map_center_lng %>"
    data-focus-listing-id="<%= @map_focus_listing_id %>"
  ></div>
  <div class="relative z-10 max-w-6xl mx-auto px-5 pt-6 space-y-3">
    <div class="flex items-start gap-3">
      <div class="flex-1 flex flex-col md:flex-row md:items-center gap-2">
        <%= render Ui::TextFieldComponent.new(name: "q", placeholder: "Tìm theo tên kèo....", icon: "search", wrapper_class: "flex-1", input_class: "bg-white/90 backdrop-blur-xl shadow-sm" ) %>
        <div class="flex items-center gap-2 overflow-x-auto pb-1 md:pb-0 md:flex-shrink-0">
          <button type="button" data-map-sport-filter="" class="px-4 h-9 rounded-full bg-primary text-white text-sm font-semibold whitespace-nowrap">Tất cả</button>
          <button type="button" data-map-sport-filter="badminton" class="px-4 h-9 rounded-full bg-white/90 text-on-surface border border-outline-variant/30 text-sm font-semibold whitespace-nowrap">Cầu lông</button>
          <button type="button" data-map-sport-filter="pickleball" class="px-4 h-9 rounded-full bg-white/90 text-on-surface border border-outline-variant/30 text-sm font-semibold whitespace-nowrap">Pickleball</button>
        </div>
      </div>
      <button id="map-locate-btn" type="button" class="w-12 h-12 bg-white/90 backdrop-blur-xl rounded-2xl flex items-center justify-center shadow-sm border border-outline-variant/20 text-primary">
        <%= render Ui::IconComponent.new(name: "my_location") %>
      </button>
    </div>

    <div class="hidden md:flex md:items-center md:justify-end gap-2">
      <label class="block w-[190px]">
        <span class="block mb-1 text-[11px] font-semibold text-on-surface-variant">Từ</span>
        <input id="map-from-input" type="datetime-local" class="w-full h-9 rounded-lg border border-outline-variant/30 bg-white/90 px-2 text-xs" />
      </label>
      <label class="block w-[190px]">
        <span class="block mb-1 text-[11px] font-semibold text-on-surface-variant">Đến</span>
        <input id="map-to-input" type="datetime-local" class="w-full h-9 rounded-lg border border-outline-variant/30 bg-white/90 px-2 text-xs" />
      </label>
    </div>
  </div>

  <%# Panel kết quả - ẩn mặc định %>
  <div id="map-results-panel" class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-2xl rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.08)] z-20 transition-transform duration-300 ease-out translate-y-full" style="height:360px">
    <%# Drag handle / collapse button %>
    <div class="flex justify-center pt-2 pb-1">
      <button id="map-panel-toggle" type="button" aria-expanded="false" class="w-16 h-5 inline-flex items-center justify-center rounded-full hover:bg-black/5">
        <span class="w-10 h-1.5 bg-outline-variant rounded-full"></span>
        <span class="sr-only">Ẩn danh sách kèo</span>
      </button>
    </div>

    <%# Tab bar %>
    <div class="px-5 flex items-center gap-1 border-b border-outline-variant/20 mb-0">
      <button id="tab-list-btn" type="button"
        class="px-4 py-2 text-sm font-semibold border-b-2 border-primary text-primary transition-colors">
        Kèo quanh đây
      </button>
      <button id="tab-detail-btn" type="button"
        class="px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant transition-colors">
        Chi tiết sân
      </button>
      <span class="flex-1"></span>
      <p id="map-result-count" class="text-on-surface-variant text-xs pr-1">Tìm thấy <%= @listings.size %> trận đấu</p>
    </div>

    <%# Tab: Kèo quanh đây %>
    <div id="tab-list-content" class="h-[calc(100%-88px)] overflow-hidden">
      <div id="map-result-list" class="flex gap-4 overflow-x-auto px-5 pt-3 pb-6 h-full">
      </div>
    </div>

    <%# Tab: Chi tiết sân %>
    <div id="tab-detail-content" class="hidden h-[calc(100%-88px)] overflow-y-auto px-5 pt-3 pb-6">
      <p class="text-sm text-on-surface-variant">Bấm vào một sân trên bản đồ để xem chi tiết.</p>
    </div>
  </div>

  <%# Nút mở rộng panel — hiện khi panel ẩn %>
  <button id="map-panel-expand-btn" type="button"
    class="absolute left-1/2 -translate-x-1/2 bottom-[calc(4rem+8px)] z-20 w-10 h-10 bg-white/95 backdrop-blur-xl rounded-full shadow-md border border-outline-variant/20 flex items-center justify-center text-primary transition-opacity duration-200">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 8l-6 6 1.41 1.41L12 10.83l4.59 4.58L18 14z"/>
    </svg>
    <span class="sr-only">Mở danh sách kèo</span>
  </button>
</div>

<%= render Ui::BottomNavComponent.new(items: [
  { path: listings_path, icon: "explore", label: "Explore", active: false },
  { path: map_path, icon: "map", label: "Map", active: true },
  { path: my_listings_path, icon: "assignment", label: "Tin của tôi", active: false },
  { path: authenticated? ? my_listings_path : new_session_path, icon: "person", label: "Profile", active: false }
]) %>

<% if ENV["GOOGLE_MAPS_API_KEY"].present? %>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= ENV["GOOGLE_MAPS_API_KEY"] %>" defer></script>
  <script src="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js" defer></script>
  <script>
    (() => {
      if (window.__sportMatchBrowseMapBound) return;
      window.__sportMatchBrowseMapBound = true;

      const normalize = (value) => (value || "").toString().trim().toLowerCase();
      const toISO = (value) => (value ? new Date(value).toISOString() : "");
      const fmt = new Intl.NumberFormat("vi-VN");
      const sportIcon = (sport) => (sport === "pickleball" ? "🏓" : "🏸");
      const debounce = (fn, waitMs) => {
        let timer = null;
        return (...args) => {
          if (timer) clearTimeout(timer);
          timer = setTimeout(() => fn(...args), waitMs);
        };
      };

      const waitForMapLib = () =>
        new Promise((resolve, reject) => {
          const startedAt = Date.now();
          const timer = setInterval(() => {
            if (window.google && window.google.maps && window.markerClusterer) {
              clearInterval(timer);
              resolve();
            } else if (Date.now() - startedAt > 12_000) {
              clearInterval(timer);
              reject(new Error("Google Maps library timeout"));
            }
          }, 120);
        });

      const svgIcon = (text) => {
        const border = "#9ca3af";
        const bg = "#ffffff";
        const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="58" viewBox="0 0 48 58">
          <path d="M24 3C13.2 3 4.5 11.7 4.5 22.5c0 13.2 15.9 29.1 18.2 31.3a1.9 1.9 0 0 0 2.6 0c2.3-2.2 18.2-18.1 18.2-31.3C43.5 11.7 34.8 3 24 3z"
            fill="${bg}" stroke="${border}" stroke-width="2.5"/>
          <text x="24" y="28.5" text-anchor="middle" font-family="Apple Color Emoji, Segoe UI Emoji, Noto Color Emoji, Arial, sans-serif" font-size="18">${text}</text>
        </svg>`;
        return {
          url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg),
          scaledSize: new google.maps.Size(48, 58),
          anchor: new google.maps.Point(24, 54)
        };
      };

      const clusterSvgIcon = (count) => {
        const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="58" height="58" viewBox="0 0 58 58">
          <circle cx="29" cy="29" r="25" fill="#ffffff" stroke="#ef4444" stroke-width="3"/>
          <text x="29" y="34" text-anchor="middle" font-family="Inter, Arial, sans-serif" font-size="16" font-weight="700" fill="#111827">${fmt.format(count)}</text>
        </svg>`;
        return {
          url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg),
          scaledSize: new google.maps.Size(58, 58),
          anchor: new google.maps.Point(29, 29)
        };
      };

      const setupBrowseMap = async () => {
        const mapEl = document.getElementById("browse-map");
        if (!mapEl) return;
        if (mapEl.dataset.initialized === "true") return;
        mapEl.dataset.initialized = "true";

        await waitForMapLib();

        const center = {
          lat: Number(mapEl.dataset.initialLat || 10.8231),
          lng: Number(mapEl.dataset.initialLng || 106.6297)
        };
        const focusListingId = (mapEl.dataset.focusListingId || "").toString();

        const locateBtn = document.getElementById("map-locate-btn");
        const queryInput = document.querySelector('input[name="q"]');
        const resultCountEl = document.getElementById("map-result-count");
        const resultListEl = document.getElementById("map-result-list");
        const panelEl = document.getElementById("map-results-panel");
        const panelToggleBtn = document.getElementById("map-panel-toggle");
        const panelExpandBtn = document.getElementById("map-panel-expand-btn");
        const tabListBtn = document.getElementById("tab-list-btn");
        const tabDetailBtn = document.getElementById("tab-detail-btn");
        const tabListContent = document.getElementById("tab-list-content");
        const tabDetailContent = document.getElementById("tab-detail-content");
        const sportFilterButtons = Array.from(document.querySelectorAll("[data-map-sport-filter]"));
        const fromInput = document.getElementById("map-from-input");
        const toInput = document.getElementById("map-to-input");
        const isDesktop = () => window.matchMedia("(min-width: 768px)").matches;

        const map = new google.maps.Map(mapEl, {
          center,
          zoom: 12,
          mapTypeControl: false,
          streetViewControl: false,
          fullscreenControl: false,
          rotateControl: false,
          gestureHandling: "greedy",
          zoomControl: true,
          styles: [
            { elementType: "geometry", stylers: [{ color: "#efefef" }] },
            { elementType: "labels.text.fill", stylers: [{ color: "#6b7280" }] },
            { elementType: "labels.text.stroke", stylers: [{ color: "#f3f4f6" }] },
            { featureType: "poi", stylers: [{ visibility: "off" }] },
            { featureType: "transit", stylers: [{ visibility: "off" }] },
            { featureType: "road", elementType: "geometry", stylers: [{ color: "#d6d9df" }] },
            { featureType: "road.highway", elementType: "geometry", stylers: [{ color: "#cfd4db" }] },
            { featureType: "water", elementType: "geometry", stylers: [{ color: "#dfe5ec" }] }
          ]
        });

        let activeSport = "";
        let sourceListings = [];
        let markersById = new Map();
        let activeMarkerIds = new Set();
        let cluster = null;
        let lastRenderedKey = "";
        let isPanelCollapsed = true;

        // ── Tab helpers ──────────────────────────────────────────────
        const switchTab = (tab) => {
          const isDetail = tab === "detail";
          tabListBtn.classList.toggle("border-primary", !isDetail);
          tabListBtn.classList.toggle("text-primary", !isDetail);
          tabListBtn.classList.toggle("border-transparent", isDetail);
          tabListBtn.classList.toggle("text-on-surface-variant", isDetail);
          tabDetailBtn.classList.toggle("border-primary", isDetail);
          tabDetailBtn.classList.toggle("text-primary", isDetail);
          tabDetailBtn.classList.toggle("border-transparent", !isDetail);
          tabDetailBtn.classList.toggle("text-on-surface-variant", !isDetail);
          tabListContent.classList.toggle("hidden", isDetail);
          tabDetailContent.classList.toggle("hidden", !isDetail);
        };

        // ── Panel open/close ─────────────────────────────────────────
        const setPanelCollapsed = (collapsed) => {
          if (!panelEl) return;
          isPanelCollapsed = collapsed;
          panelEl.classList.toggle("translate-y-full", collapsed);
          panelEl.classList.toggle("translate-y-0", !collapsed);
          panelToggleBtn.setAttribute("aria-expanded", String(!collapsed));
          if (panelExpandBtn) panelExpandBtn.classList.toggle("hidden", !collapsed);
        };

        const openPanel = (tab = "list") => {
          switchTab(tab);
          setPanelCollapsed(false);
        };

        const listingCardHtml = (item) => {
          const startAt = item.start_at ? new Date(item.start_at) : null;
          const timeLabel = startAt
            ? startAt.toLocaleString("vi-VN", {
                day: "2-digit",
                month: "2-digit",
                hour: "2-digit",
                minute: "2-digit"
              })
            : "Chưa cập nhật";
          const sportLabel = item.sport === "pickleball" ? "Pickleball" : "Cầu lông";
          return `
            <div data-listing-card data-listing-id="${item.id}" data-lat="${item.lat}" data-lng="${item.lng}"
              class="cursor-pointer min-w-[240px] max-w-[260px] rounded-2xl border border-outline-variant/30 bg-white p-3 shadow-sm active:bg-surface-container hover:shadow-md transition-shadow">
              <p class="text-[11px] text-on-surface-variant font-semibold">${sportLabel}</p>
              <p class="mt-1 text-sm font-semibold text-on-surface line-clamp-2">${item.title || ""}</p>
              <p class="mt-1 text-xs text-on-surface-variant line-clamp-1">${item.location_name || ""}</p>
              <p class="mt-2 text-xs text-on-surface-variant">${timeLabel}</p>
            </div>
          `;
        };

        const listingDetailHtml = (item) => {
          const startAt = item.start_at ? new Date(item.start_at) : null;
          const timeLabel = startAt
            ? startAt.toLocaleString("vi-VN", {
                weekday: "short",
                day: "2-digit",
                month: "2-digit",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit"
              })
            : "Chưa cập nhật";
          const sportLabel = item.sport === "pickleball" ? "Pickleball" : "Cầu lông";
          const icon = sportIcon(item.sport);
          return `
            <div class="space-y-3">
              <div class="flex items-center gap-2">
                <span class="text-2xl">${icon}</span>
                <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide">${sportLabel}</span>
              </div>
              <h3 class="font-headline font-extrabold text-lg leading-snug text-on-surface">${item.title || ""}</h3>
              <div class="flex flex-col gap-1.5 text-sm text-on-surface-variant">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                  <span class="line-clamp-2">${item.location_name || "Chưa có địa điểm"}</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
                  <span>${timeLabel}</span>
                </div>
              </div>
              <a href="/listings/${item.id}"
                class="mt-4 inline-flex items-center justify-center w-full h-10 rounded-xl bg-primary text-white text-sm font-semibold gap-2">
                Xem trang sân
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
              </a>
            </div>
          `;
        };

        const renderResultList = (items) => {
          if (!resultListEl) return;
          if (items.length === 0) {
            resultListEl.innerHTML = '<p class="text-sm text-on-surface-variant py-2">Không có kèo phù hợp với bộ lọc hiện tại.</p>';
            return;
          }
          resultListEl.innerHTML = items.map((item) => listingCardHtml(item)).join("");
          // Gắn event click cho từng card
          resultListEl.querySelectorAll("[data-listing-card]").forEach((card) => {
            card.addEventListener("click", () => {
              const id = card.dataset.listingId;
              const lat = Number(card.dataset.lat);
              const lng = Number(card.dataset.lng);
              const item = sourceListings.find((l) => String(l.id) === String(id));
              if (Number.isFinite(lat) && Number.isFinite(lng)) {
                map.panTo({ lat, lng });
                map.setZoom(15);
              }
              if (item) {
                tabDetailContent.innerHTML = listingDetailHtml(item);
                openPanel("detail");
              }
            });
          });
        };

        const ensureCluster = () => {
          if (cluster) return cluster;
          cluster = new markerClusterer.MarkerClusterer({
            map,
            markers: [],
            renderer: {
              render: ({ count, position }) =>
                new google.maps.Marker({
                  position,
                  icon: clusterSvgIcon(count),
                  zIndex: Number(google.maps.Marker.MAX_ZINDEX) + count
                })
            }
          });
          return cluster;
        };

        const getOrBuildMarker = (item) => {
          const key = String(item.id);
          const existing = markersById.get(key);
          if (existing) return existing;

          const marker = new google.maps.Marker({
            position: { lat: Number(item.lat), lng: Number(item.lng) },
            title: item.title,
            icon: svgIcon(sportIcon(item.sport))
          });
          marker.addListener("click", () => {
            map.panTo({ lat: Number(item.lat), lng: Number(item.lng) });
            map.setZoom(15);
            tabDetailContent.innerHTML = listingDetailHtml(item);
            openPanel("detail");
          });
          markersById.set(key, marker);
          return marker;
        };

        const renderMarkers = (items) => {
          const validItems = items.filter((item) => Number.isFinite(Number(item.lat)) && Number.isFinite(Number(item.lng)));
          const nextIds = new Set(validItems.map((item) => String(item.id)));
          const validItemsById = new Map(validItems.map((item) => [String(item.id), item]));
          const renderKey = Array.from(nextIds).sort().join(",");
          if (renderKey === lastRenderedKey) {
            if (resultCountEl) resultCountEl.textContent = "Tìm thấy " + items.length + " trận đấu";
            return;
          }
          lastRenderedKey = renderKey;

          const activeCluster = ensureCluster();
          const toAdd = [];
          const toRemove = [];

          nextIds.forEach((id) => {
            if (!activeMarkerIds.has(id)) {
              const item = validItemsById.get(id);
              if (item) toAdd.push(getOrBuildMarker(item));
            }
          });
          activeMarkerIds.forEach((id) => {
            if (!nextIds.has(id)) {
              const marker = markersById.get(id);
              if (marker) toRemove.push(marker);
            }
          });

          if (toRemove.length > 0) activeCluster.removeMarkers(toRemove);
          if (toAdd.length > 0) activeCluster.addMarkers(toAdd);
          activeMarkerIds = nextIds;

          if (resultCountEl) {
            resultCountEl.textContent = "Tìm thấy " + items.length + " trận đấu";
          }
          renderResultList(validItems);
        };

        const applyClientFilters = () => {
          const q = normalize(queryInput && queryInput.value);
          const filtered = sourceListings.filter((item) => {
            const matchSport = activeSport ? item.sport === activeSport : true;
            const haystack = normalize(item.title);
            const matchQuery = q ? haystack.includes(q) : true;
            return matchSport && matchQuery;
          });
          renderMarkers(filtered);
        };

        const fetchListings = async () => {
          const params = new URLSearchParams();
          if (isDesktop()) {
            if (fromInput && fromInput.value) params.set("from", toISO(fromInput.value));
            if (toInput && toInput.value) params.set("to", toISO(toInput.value));
          }

          const resp = await fetch("/api/v1/listings/map?" + params.toString());
          if (!resp.ok) throw new Error("map feed failed");
          const json = await resp.json();
          sourceListings = json.listings || [];
          applyClientFilters();

          if (focusListingId) {
            const focused = sourceListings.find((item) => String(item.id) === focusListingId);
            if (focused && Number.isFinite(Number(focused.lat)) && Number.isFinite(Number(focused.lng))) {
              map.panTo({ lat: Number(focused.lat), lng: Number(focused.lng) });
              map.setZoom(15);
            }
          }
        };

        const refetchWithCurrentFilters = () => {
          fetchListings().catch((error) => {
            console.error("Khong tai duoc du lieu map", error);
          });
        };

        sportFilterButtons.forEach((btn) => {
          btn.addEventListener("click", () => {
            activeSport = btn.dataset.mapSportFilter || "";
            sportFilterButtons.forEach((el) => {
              const isActive = el === btn;
              el.classList.toggle("bg-primary", isActive);
              el.classList.toggle("text-white", isActive);
              el.classList.toggle("bg-white/90", !isActive);
              el.classList.toggle("text-on-surface", !isActive);
              el.classList.toggle("border", !isActive);
              el.classList.toggle("border-outline-variant/30", !isActive);
            });
            applyClientFilters();
          });
        });

        if (queryInput) {
          queryInput.addEventListener("input", debounce(applyClientFilters, 250));
        }
        if (fromInput) {
          fromInput.addEventListener("change", refetchWithCurrentFilters);
        }
        if (toInput) {
          toInput.addEventListener("change", refetchWithCurrentFilters);
        }

        if (locateBtn) {
          locateBtn.addEventListener("click", () => {
            if (!navigator.geolocation) return;
            navigator.geolocation.getCurrentPosition(
              (pos) => {
                map.panTo({ lat: pos.coords.latitude, lng: pos.coords.longitude });
                map.setZoom(14);
              },
              () => {}
            );
          });
        }
        if (panelToggleBtn) {
          panelToggleBtn.addEventListener("click", () => {
            setPanelCollapsed(true);
          });
        }
        if (panelExpandBtn) {
          panelExpandBtn.addEventListener("click", () => {
            openPanel("list");
          });
        }
        if (tabListBtn) {
          tabListBtn.addEventListener("click", () => switchTab("list"));
        }
        if (tabDetailBtn) {
          tabDetailBtn.addEventListener("click", () => switchTab("detail"));
        }

        // Khởi tạo: panel ẩn, nút expand hiện
        setPanelCollapsed(true);

        refetchWithCurrentFilters();
      };

      document.addEventListener("turbo:load", () => {
        setupBrowseMap().catch((error) => {
          console.error("Khong khoi tao duoc map", error);
        });
      });
    })();
  </script>
<% else %>
  <div class="fixed top-20 left-1/2 -translate-x-1/2 z-40 w-[92%] max-w-xl rounded-2xl border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900 shadow">
