<% content_for :title, "Đăng nhập — Giao Luu" %>

<%= render Ui::TopAppBarComponent.new(title: "SportMatch", back_href: root_path, back_icon: "arrow_back") %>

<%= render Ui::PageShellComponent.new(
      padding_top: "pt-24",
      padding_bottom: "pb-12",
      max_width: "max-w-[335px]",
      horizontal_padding: "px-5",
      extra_class: "min-h-[calc(100vh-64px)] flex flex-col items-center justify-center mx-auto"
    ) do %>
  <div class="w-full space-y-8">
    <div class="text-center space-y-2">
      <h1 class="font-headline text-4xl font-extrabold tracking-tight text-primary">Đăng nhập</h1>
      <p class="text-on-surface-variant font-medium text-sm">Chào mừng bạn quay lại với đấu trường.</p>
    </div>

    <%= form_with url: session_path, class: "space-y-6" do |f| %>
      <div class="space-y-1.5">
        <%= render Ui::FieldLabelComponent.new("Email", for_id: "email_address", uppercase: true, class: "font-headline text-[10px] font-bold tracking-widest uppercase text-on-surface-variant px-1") %>
        <%= render Ui::TextFieldComponent.new(
              form: f,
              attribute: :email_address,
              type: "email",
              placeholder: "username@email.com",
              id: "email_address",
              input_class: "h-14 px-4 shadow-sm focus:ring-1 focus:ring-primary"
            ) %>
      </div>

      <div class="space-y-1.5">
        <%= render Ui::FieldLabelComponent.new("Mật khẩu", for_id: "password", uppercase: true, class: "font-headline text-[10px] font-bold tracking-widest uppercase text-on-surface-variant px-1") %>
        <div class="relative">
          <%= render Ui::TextFieldComponent.new(
                form: f,
                attribute: :password,
                type: "password",
                placeholder: "••••••••",
                id: "password",
                input_class: "h-14 px-4 pr-12 shadow-sm focus:ring-1 focus:ring-primary"
              ) %>
          <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors" aria-label="Hiện mật khẩu">
            <%= render Ui::IconComponent.new(name: "visibility", size_class: "text-xl") %>
          </button>
        </div>
        <div class="flex justify-end">
          <%= link_to "Quên mật khẩu?", new_password_path, class: "font-body text-xs font-semibold text-primary underline decoration-surface-variant hover:decoration-primary transition-all underline-offset-4" %>
        </div>
      </div>

      <div class="pt-4">
        <%= button_tag type: "submit", class: "w-full h-14 bg-primary text-on-primary-container font-headline font-bold text-base rounded-xl active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-xl shadow-black/10" do %>
          Đăng nhập
          <%= render Ui::IconComponent.new(name: "login", size_class: "text-lg") %>
        <% end %>
      </div>
    <% end %>

    <div class="text-center">
      <span class="text-[12px] text-on-surface-variant">Chưa có tài khoản?</span>
      <%= link_to "Đăng ký", new_user_path, class: "ml-1 font-bold underline decoration-zinc-300 hover:text-primary" %>
    </div>
  </div>
<% end %>
