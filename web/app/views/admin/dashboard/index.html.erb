<% content_for :title, "Dashboard — Admin SportMatch" %>

<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-gray-500 text-sm mt-1">Xin chào, <strong><%= current_admin.email_address %></strong></p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= link_to new_admin_facebook_import_path,
          class: "block bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition group" do %>
      <div class="text-3xl mb-3">📋</div>
      <h2 class="font-semibold text-gray-900 group-hover:text-blue-700">Import từ Facebook</h2>
      <p class="text-sm text-gray-500 mt-1">Paste nội dung bài viết → AI phân tích → lưu listing</p>
    <% end %>

    <%= link_to listings_path,
          class: "block bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition group" do %>
      <div class="text-3xl mb-3">📍</div>
      <h2 class="font-semibold text-gray-900 group-hover:text-blue-700">Xem tất cả Listings</h2>
      <p class="text-sm text-gray-500 mt-1">Danh sách tin đã đăng trên hệ thống</p>
    <% end %>
  </div>
</div>
