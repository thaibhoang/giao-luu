<% content_for :title, "Admin Đăng nhập — SportMatch" %>

<div class="min-h-[80vh] flex items-center justify-center">
  <div class="bg-white shadow-md rounded-2xl p-8 w-full max-w-sm space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-gray-900">Admin Login</h1>
      <p class="text-gray-500 text-sm mt-1">SportMatch — Khu vực quản trị</p>
    </div>

    <%= form_with url: admin_session_path, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :email_address, "Email", class: "block text-xs font-semibold text-gray-600 uppercase tracking-widest mb-1" %>
        <%= f.email_field :email_address, placeholder: "admin@example.com", required: true,
              class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gray-800" %>
      </div>
      <div>
        <%= f.label :password, "Mật khẩu", class: "block text-xs font-semibold text-gray-600 uppercase tracking-widest mb-1" %>
        <%= f.password_field :password, placeholder: "••••••••", required: true,
              class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gray-800" %>
      </div>
      <%= f.submit "Đăng nhập",
            class: "w-full bg-gray-900 text-white rounded-lg py-3 text-sm font-semibold hover:bg-gray-700 transition cursor-pointer" %>
    <% end %>
  </div>
</div>
