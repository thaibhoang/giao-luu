# Sao chép thành `.env` ở gốc repo (docker compose đọc file này nếu có).
# Không commit `.env`.

# Bắt buộc nếu container Rails cần giải mã credentials (khớp nội dung web/config/master.key)
# RAILS_MASTER_KEY=
# SCRAPER_HMAC_SECRET=change-me
# GOOGLE_MAPS_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Rails chạy trên máy, DB là PostGIS trong Docker (docker compose) ---
# Sao chép các dòng sau vào web/.env (hoặc export trước khi chạy bin/rails):
# DATABASE_HOST=localhost
# DATABASE_PORT=54322
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
#
# Cần PostGIS trên đúng server: nếu dùng Postgres cài sẵn trên máy (ví dụ 5432) thì phải cài gói
# postgresql-XX-postgis-3 hoặc tương đương, hoặc trỏ DATABASE_* sang container như trên.
